{
  "name": "pc-system-info-mcp",
  "version": "1.0.0",
  "description": "MCP Server for monitoring PC system information (CPU/GPU temperature, RAM, VRAM, Fan, Disk, Network) on Windows and macOS",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build"
  },
  "bin": {
    "pc-system-info-mcp": "dist/index.js"
  },
  "keywords": [
    "mcp",
    "system-info",
    "cpu-temperature",
    "gpu-temperature",
    "nvidia",
    "ram",
    "vram",
    "monitoring",
    "claude",
    "openclaw"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
