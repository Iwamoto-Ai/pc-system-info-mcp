{
  "mcp": {
    "servers": {
      "pc-system-info": {
        "command": "node",
        "args": [
          "/home/YourName/pc-system-info-mcp/dist/index.js"
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/mistral-nemo"
      },
      "thinkingDefault": "off"
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "models": [
          {
            "id": "mistral-nemo",
            "name": "Mistral NeMo 12B",
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 4096
          }
        ]
      }
    }
  }
}
